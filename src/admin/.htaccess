# Admin DocRoot — admin-sporeprint.pilzling.eu
#
# WICHTIG: Diese Datei enthaelt ZWEI Bloecke:
#   1) App-eigenes Hardening (von uns gepflegt, im Repo versioniert)
#   2) cPanel-verwalteter Verzeichnisschutz (Auth-Direktiven, NICHT manuell editieren!)
#
# Warum beide hier in einer Datei?
# WinSCP-Auto-Deploy synct lokale src/admin/.htaccess → Server. Wenn der cPanel-Block
# in der lokalen Datei fehlt, ueberschreibt WinSCP die Server-Version und der
# Verzeichnisschutz geht verloren. Daher: kompletten Block (inkl. cp:ppd-Marker)
# im Repo halten.
#
# Wenn der Verzeichnisschutz-User oder das Passwort in cPanel geaendert wird,
# muss der cp:ppd-Block hier in src/admin/.htaccess manuell nachgezogen werden
# (User-Aenderung selten — pragmatisch ok).

# === App-eigenes Hardening ===

# .env-Dateien blockieren
<Files .env>
    Order allow,deny
    Deny from all
</Files>
<Files .env.example>
    Order allow,deny
    Deny from all
</Files>
<FilesMatch "^\.env\..*$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Verzeichnislisting deaktivieren
Options -Indexes

# UTF-8 als Default
AddDefaultCharset UTF-8

#----------------------------------------------------------------cp:ppd
# Section managed by cPanel: Password Protected Directories     -cp:ppd
# - Do not edit this section of the htaccess file!              -cp:ppd
#----------------------------------------------------------------cp:ppd
AuthType Basic
AuthName "Protected 'app.reviews/admin'"
AuthUserFile "/home/pilzling/.htpasswds/app.reviews/admin/passwd"
Require valid-user
#----------------------------------------------------------------cp:ppd
# End section managed by cPanel: Password Protected Directories -cp:ppd
#----------------------------------------------------------------cp:ppd
